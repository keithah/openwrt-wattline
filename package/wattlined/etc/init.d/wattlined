#!/bin/sh /etc/rc.common
# procd service for wattlined
USE_PROCD=1
START=95
STOP=10

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/wattlined -config /etc/config/wattline
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	# SIGHUP: wattlined re-reads rules without dropping the BLE link.
	local pid
	pid="$(pgrep -f /usr/bin/wattlined)"
	[ -n "$pid" ] && kill -HUP "$pid"
}

service_triggers() {
	procd_add_reload_trigger "wattline"
}
