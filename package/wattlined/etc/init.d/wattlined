#!/bin/sh /etc/rc.common
# procd service for wattlined
USE_PROCD=1
START=95
STOP=10
RUNTIME_DIR="${RUNTIME_DIR:-/var/run/wattline}"
DAEMON_STATE="${DAEMON_STATE:-$RUNTIME_DIR/daemon-state}"
FIREWALL_SYNC="${FIREWALL_SYNC:-/usr/lib/wattline/firewall-sync}"
VPN_REPAIR="${VPN_REPAIR:-/usr/lib/wattline/vpn-firewall-repair}"
SERVICE_SCRIPT="${SERVICE_SCRIPT:-/etc/init.d/wattlined}"
PGREP="${PGREP:-pgrep}"

daemon_state() {
	# wattlined only reloads rule sections on SIGHUP. Any main-section change
	# therefore needs a process restart, including auth, discovery, and WAN
	# policy in addition to listener/TLS settings.
	uci -q show wattline.main 2>/dev/null
}

repair_vpn_firewall() {
	[ ! -x "$VPN_REPAIR" ] || "$VPN_REPAIR" || true
}

save_daemon_state() {
	local temporary
	temporary="$DAEMON_STATE.new.$$"
	mkdir -p "$RUNTIME_DIR" || return 1
	chmod 0700 "$RUNTIME_DIR" || return 1
	if ! daemon_state > "$temporary"; then
		rm -f "$temporary"
		return 1
	fi
	if ! chmod 0600 "$temporary"; then
		rm -f "$temporary"
		return 1
	fi
	if ! mv "$temporary" "$DAEMON_STATE"; then
		rm -f "$temporary"
		return 1
	fi
}

start_service() {
	"$FIREWALL_SYNC" || return 1
	repair_vpn_firewall
	save_daemon_state || return 1
	procd_open_instance
	procd_set_param command /usr/bin/wattlined -config /etc/config/wattline
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	"$FIREWALL_SYNC" || return 1
	repair_vpn_firewall
	current="$(daemon_state)" || return 1
	previous="$(cat "$DAEMON_STATE" 2>/dev/null)" || return 1
	if [ "$current" != "$previous" ]; then
		"$SERVICE_SCRIPT" restart
		return
	fi
	# Rule-only changes retain the BLE link and reload with SIGHUP.
	local pid
	for pid in $("$PGREP" -f '/usr/bin/wattlined -config /etc/config/wattline' || true); do
		kill -HUP "$pid"
	done
}

service_triggers() {
	procd_add_reload_trigger "wattline"
}

# Lightweight readiness probe used by dependent services after restart.
# Do not mutate service state; simply verify the configured daemon process
# is present.
health() {
	"$PGREP" -f '/usr/bin/wattlined -config /etc/config/wattline' >/dev/null 2>&1
}
