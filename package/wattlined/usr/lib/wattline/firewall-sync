#!/bin/sh
set -eu

FIREWALL_INIT="${FIREWALL_INIT:-/etc/init.d/firewall}"
APPLY_MARKER="${APPLY_MARKER:-/var/run/wattline-firewall.pending}"
changed=0

# Serialize procd reloads and hotplug events when OpenWrt's lock helper is
# available. Reconciliation remains idempotent on minimal images without it.
if command -v lock >/dev/null 2>&1; then
	LOCK_FILE=/var/lock/wattline-firewall
	lock "$LOCK_FILE"
	trap 'lock -u "$LOCK_FILE"' EXIT HUP INT TERM
fi

get() {
	uci -q get "$1" 2>/dev/null
}

value_or() {
	value="$(get "$1" || true)"
	printf '%s\n' "${value:-$2}"
}

set_if_changed() {
	key="$1"
	value="$2"
	current="$(get "$key" || true)"
	if [ "$current" != "$value" ]; then
		uci -q set "$key=$value"
		changed=1
	fi
}

delete_if_present() {
	if uci -q show "$1" >/dev/null 2>&1; then
		uci -q delete "$1"
		changed=1
	fi
}

sync_rule() {
	section="$1"
	name="$2"
	port="$3"
	set_if_changed "firewall.$section" rule
	set_if_changed "firewall.$section.name" "$name"
	set_if_changed "firewall.$section.src" wan
	set_if_changed "firewall.$section.proto" tcp
	set_if_changed "firewall.$section.dest_port" "$port"
	set_if_changed "firewall.$section.target" ACCEPT
	set_if_changed "firewall.$section.enabled" 1
}

rule_is_exact() {
	section="$1"
	name="$2"
	port="$3"
	[ "$(get "firewall.$section" || true)" = rule ] || return 1
	[ "$(get "firewall.$section.name" || true)" = "$name" ] || return 1
	[ "$(get "firewall.$section.src" || true)" = wan ] || return 1
	[ "$(get "firewall.$section.proto" || true)" = tcp ] || return 1
	[ "$(get "firewall.$section.dest_port" || true)" = "$port" ] || return 1
	[ "$(get "firewall.$section.target" || true)" = ACCEPT ] || return 1
	[ "$(get "firewall.$section.enabled" || true)" = 1 ] || return 1
	for key in $(uci -q show "firewall.$section" 2>/dev/null | sed -n "s/^firewall\.$section\.\([^=]*\)=.*/\1/p"); do
		case "$key" in
			name|src|proto|dest_port|target|enabled) ;;
			*) return 1 ;;
		esac
	done
	return 0
}

reconcile_rule() {
	section="$1"
	name="$2"
	port="$3"
	if rule_is_exact "$section" "$name" "$port"; then
		return
	fi
	delete_if_present "firewall.$section"
	sync_rule "$section" "$name" "$port"
}

valid_port() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
	esac
	[ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

if [ "$(value_or wattline.main.wan_access 0)" = 1 ]; then
	http_enabled="$(value_or wattline.main.http_enabled 1)"
	https_enabled="$(value_or wattline.main.https_enabled 1)"
	http_port="$(value_or wattline.main.port 8377)"
	https_port="$(value_or wattline.main.https_port 8378)"
	[ "$http_enabled" != 1 ] || valid_port "$http_port" || { logger 'wattline: refusing invalid HTTP WAN port'; exit 1; }
	[ "$https_enabled" != 1 ] || valid_port "$https_port" || { logger 'wattline: refusing invalid HTTPS WAN port'; exit 1; }
	if [ "$http_enabled" = 1 ]; then
		reconcile_rule wattline_http 'Wattline HTTP' "$http_port"
	else
		delete_if_present firewall.wattline_http
	fi
	if [ "$https_enabled" = 1 ]; then
		reconcile_rule wattline_https 'Wattline HTTPS' "$https_port"
	else
		delete_if_present firewall.wattline_https
	fi
else
	delete_if_present firewall.wattline_http
	delete_if_present firewall.wattline_https
fi

if [ "$changed" -eq 1 ]; then
	mkdir -p "$(dirname "$APPLY_MARKER")"
	: > "$APPLY_MARKER"
	if ! uci -q commit firewall; then
		rm -f "$APPLY_MARKER"
		exit 1
	fi
	if [ "$(value_or wattline.main.wan_access 0)" = 1 ]; then
		logger 'wattline: WAN access enabled: insecure — use TLS/VPN'
	fi
fi

if [ "$changed" -eq 1 ] || [ -e "$APPLY_MARKER" ]; then
	if "$FIREWALL_INIT" reload; then
		rm -f "$APPLY_MARKER"
	else
		exit 1
	fi
fi
